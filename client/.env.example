# Google OAuth 2.0 Client ID
# Get this from: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console
# 2. Create a project or select existing
# 3. Go to APIs & Services > Credentials
# 4. Create OAuth 2.0 Client ID (Web application type)
# 5. Add authorized JavaScript origins (e.g., http://localhost:5173)
# 6. Add authorized redirect URIs (e.g., http://localhost:5173)
# 7. Copy the Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL (for Google token verification)
# Your backend must implement POST /api/auth/google
# Expected request: { credential: "google_id_token" }
# Expected response: { token: "jwt_token", user: { ... } }
VITE_API_URL=http://localhost:8000
