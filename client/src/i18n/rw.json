  "faq": {
    "pageTitle": "Ibibazo - Road Rules",
    "title": "Ibibazo Bikunze Kubazwa",
    "subtitle": "Ibyose ugomba kumenya kuri Road Rules",
    "questions": {
      "account": {
        "q": "Nigute nkora konti?",
        "a": "Kanda buto ya \"Kwiyandikisha\" hejuru iburyo, wujuje amakuru yawe (izina, imeyili, ijambo ry'ibanga) hanyuma wohereze. Uzabona imeyili yo gushimangira konti yawe."
      },
      "free": {
        "q": "Uru rubuga ruboreshwa ubuntu?",
        "a": "Yego! Duha ibizamini by'ubuntu, amashusho, n'ibimenyetso. Ibikoresho by'ibanze bisaba ubwishyu."
      },
      "subscription": {
        "q": "Nigute nguramo ubwishyu?",
        "a": "Jya ku rupapuro rw'ibiciro, hitamo gahunda, hanyuma wemere ubwishyu bwa MTN MoMo, Airtel Money, cyangwa Visa/Mastercard."
      },
      "attempts": {
        "q": "Ni kangahe nemerewe gukora ikizamini?",
        "a": "Ibizamini by'ubuntu bituma ukora inshuro 3. Ibizamini by'ibanze nta kugabanyirwa kugerageza."
      },
      "certificate": {
        "q": "Nigute mbona icyemezo cyanje?",
        "a": "Tsinda ikizamini cya Premium ku manota 80% cyangwa hejuru. Icyemezo kizaboneka mu buryo bwa PDF."
      },
      "materials": {
        "q": "Nshobora gukuramo ibikoresho by'amasomo?",
        "a": "Inyandiko z'ubuntu zishobora gukurwamo igihe icyo ari cyo cyose. Inyandiko za Premium zisaba ubwishyu."
      },
      "aiChat": {
        "q": "AI Chat ikora bite?",
        "a": "AI Ifasha ishobora gusubiza ibibazo byawe byerekeye amategeko y'umuhanda yishakisha mu bitabo by'isomero."
      },
      "payment": {
        "q": "Ni ubuhe buryo bw'ubwishyu bwemewe?",
        "a": "Twemera MTN MoMo, Airtel Money, na Visa/Mastercard."
      },
      "resetPassword": {
        "q": "Nigute ngarura ijambo ry'ibanga?",
        "a": "Kanda \"Forgot Password\" ku rupapuro rwo kwinjira, winjize imeyili yawe, hanyuma ukurikize amabwiriza yoherejwe."
      },
      "mobile": {
        "q": "Nshobora gukoresha urubuga kuri terefone?",
        "a": "Yego! Urubuga rukora neza ku bikoresho byose."
      }
    }
  },
