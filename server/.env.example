# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=road_rules
DB_SSL=false

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# MTN Rwanda MoMo API
# Get subscription key at https://momodeveloper.mtn.com
MTN_API_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user
MTN_API_KEY=your_mtn_api_key
MTN_TARGET_ENVIRONMENT=sandbox

# MoMo Payment Config
MOMO_API_KEY=your_momo_api_key
MOMO_API_SECRET=your_momo_api_secret
MOMO_ENVIRONMENT=sandbox

# Airtel Money Rwanda API
# Get credentials at https://developers.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_API_KEY=your_airtel_api_key

# Stripe (Visa/Mastercard)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AI (Groq with Llama 3)
# Sign up free at https://console.groq.com
AI_API_KEY=gsk_your_groq_api_key
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_BASE_URL=https://api.groq.com/openai/v1
AI_CHAT_MAX_CONTEXT=10

# Search API (Optional - for RAG internet search)
# Google Custom Search JSON API
SEARCH_URL=https://www.googleapis.com/customsearch/v1/siterestrict
SEARCH_API_KEY=your_google_search_api_key
SEARCH_ENGINE_ID=your_search_engine_id

# Frontend URL
CLIENT_URL=http://localhost:5173
